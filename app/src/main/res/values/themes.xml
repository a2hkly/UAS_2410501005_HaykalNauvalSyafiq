        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/purple_light</item>
    </style>

    <style name="Theme.UAScoba" parent="Base.Theme.UAScoba" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
